---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} — Stone &amp; Key Consulting`}
  description={post.data.description}
>
  <article class="blog-post" style="padding-top: 8rem;">
    <div class="container">
      <a href={`${import.meta.env.BASE_URL}blog/`} class="back-link">&larr; Back to blog</a>

      <header class="post-header">
        <p class="eyebrow">
          {post.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </p>
        <h1>{post.data.title}</h1>
        <p class="post-lede">{post.data.description}</p>
        {post.data.tags && (
          <div class="tags">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="post-body prose">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .blog-post {
    min-height: 70vh;
    padding-bottom: var(--section-pad-y);
  }
  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--ink-2);
    margin-bottom: 2rem;
    border-bottom: none;
  }
  .back-link:hover {
    color: var(--brass);
  }
  .post-header {
    margin-bottom: 3rem;
    max-width: var(--measure);
  }
  .post-header h1 {
    margin-top: 0.5rem;
    font-size: clamp(2rem, 4vw, 3rem);
  }
  .post-lede {
    font-size: 1.1rem;
    color: var(--ink-1);
    margin-top: 0.5rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--brass);
    background: rgba(200, 162, 107, 0.08);
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
  }
  .post-body {
    max-width: var(--measure);
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .post-body h2 {
    margin-top: 2.5rem;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
  }
  .post-body h3 {
    margin-top: 2rem;
  }
  .post-body p {
    margin-bottom: 1.25rem;
  }
  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.92rem;
  }
  .post-body :global(th, td) {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--rule);
    text-align: left;
  }
  .post-body :global(th) {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--ink-2);
    text-transform: uppercase;
  }
  .post-body :global(td) {
    color: var(--ink-1);
  }
  .post-body :global(strong) {
    font-weight: 600;
    color: var(--ink-0);
  }
  .post-body :global(em) {
    font-style: italic;
  }
  .post-body :global(ul, ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }
  .post-body :global(li) {
    color: var(--ink-1);
    margin-bottom: 0.3rem;
  }
  .post-body :global(blockquote) {
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    border-left: 2px solid var(--brass);
    background: rgba(200, 162, 107, 0.04);
    color: var(--ink-1);
    font-style: italic;
  }
  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 2.5rem 0;
  }
  .post-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--bg-1);
    padding: 0.15em 0.4em;
    border-radius: 2px;
  }
  .post-body :global(pre) {
    background: var(--bg-1);
    padding: 1rem 1.25rem;
    border-radius: 4px;
    overflow-x: auto;
    border: 1px solid var(--rule);
  }
  .post-body :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
  }
  .post-body :global(img) {
    border-radius: 4px;
    margin: 1.5rem 0;
  }
</style>
