---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const allPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="Blog — Stone &amp; Key Consulting" description="Thoughts on open-source strategy, developer communities, and ecosystem building.">
  <section class="blog-listing" style="padding-top: 8rem;">
    <div class="container">
      <p class="eyebrow">Writing</p>
      <h1>Blog</h1>
      <p class="lede" style="max-width: 48ch;">
        Thoughts on open-source strategy, developer communities, and ecosystem
        building — from the trenches.
      </p>

      {
        allPosts.length > 0 ? (
          <div class="post-list">
            {
              allPosts.map((post, i) => (
                <article class="post-card">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                  <h2>
                    <a href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>{post.data.title}</a>
                  </h2>
                  <p>{post.data.description}</p>
                  {post.data.tags && (
                    <div class="tags">
                      {post.data.tags.map((tag) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </article>
              ))
            }
          </div>
        ) : (
          <p style="margin-top: 3rem; color: var(--ink-2);">
            No posts yet. Check back soon.
          </p>
        )
      }

      <p class="rss-link">
        <a href={`${import.meta.env.BASE_URL}rss.xml`}>Subscribe via RSS</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .blog-listing {
    min-height: 70vh;
    padding-bottom: var(--section-pad-y);
  }
  .post-list {
    display: grid;
    gap: 2.5rem;
    margin-top: 3rem;
    max-width: 56ch;
  }
  .post-card {
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2.5rem;
  }
  .post-card:last-of-type {
    border-bottom: none;
  }
  .post-card time {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-2);
    letter-spacing: 0.1em;
  }
  .post-card h2 {
    margin: 0.3rem 0 0.5rem;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
  }
  .post-card h2 a {
    color: var(--ink-0);
    border-bottom: none;
  }
  .post-card h2 a:hover {
    color: var(--brass);
  }
  .post-card p {
    font-size: 0.96rem;
    color: var(--ink-1);
    margin: 0;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--brass);
    background: rgba(200, 162, 107, 0.08);
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
  }
  .rss-link {
    margin-top: 3rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .rss-link a {
    color: var(--ink-2);
    border-bottom: none;
  }
  .rss-link a:hover {
    color: var(--brass);
  }
</style>
